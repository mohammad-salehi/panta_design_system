{
  "name": "panta_design_system",
  "version": "1.0.0",
  "description": "Design system with dark/light theme for Next.js",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && npm run copy-styles",
    "copy-styles": "shx cp src/styles/global.css dist/styles.css",
    "prepublishOnly": "npm run build",
    "dev": "tsup --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "design-system",
    "nextjs",
    "dark-mode",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "next-themes": "^0.4.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "shx": "^0.4.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  }
}